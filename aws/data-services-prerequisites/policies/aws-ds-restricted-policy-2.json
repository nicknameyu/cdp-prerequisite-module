{
  "Version": "2012-10-17",
  "Id": "ComputePolicy_v12_added_permissions",
  "Statement": [
    {
      "Sid": "AddedPermissions",
      "Effect": "Allow",
      "Action": [
        "iam:CreateRole",
        "iam:AttachRolePolicy",
        "kms:CreateKey"
      ],
      "Resource": "*",
      "Condition": {
        "StringLike": {
          "aws:ResourceTag/Cloudera-Resource-Name": [
            "crn:cdp:*"
          ]
        }
      }
    }
  ]
}